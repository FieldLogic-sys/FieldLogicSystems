@page "/tracker"
@using FieldLogic.Shared
@using FieldLogic.Web.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveAuto

<PageTitle>Media Archive | FieldLogic</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="text-blue-500 font-black mb-6 uppercase tracking-tighter">
        Field Intelligence: Media Archive
    </MudText>

    @* Manual Entry Module *@
    <MudPaper Elevation="4" Class="p-6 bg-slate-900 border border-slate-800 rounded-xl mb-8">
        <MudText Typo="Typo.overline" Class="text-blue-400 mb-4 font-mono">Commissioning New Entry</MudText>
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_newEntry.Title" Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField @bind-Value="_newEntry.Progress" Label="EP" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_newEntry.Status" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Watching")">Watching</MudSelectItem>
                    <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem Value="@("Plan to Watch")">Plan to Watch</MudSelectItem>
                    <MudSelectItem Value="@("Dropped")">Dropped</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton OnClick="AddMedia" Variant="Variant.Filled" Color="Color.Primary" FullWidth Class="py-3 font-black">
                    COMMIT TO SSD
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Data Table *@
    <MudTable Items="@_myMedia" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="4" Class="bg-slate-900/50 border border-slate-800">
        <HeaderContent>
            <MudTh>TITLE</MudTh>
            <MudTh>TYPE</MudTh>
            <MudTh>PROGRESS</MudTh>
            <MudTh>STATUS</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">
                @if (_editingId == context.Id)
                {
                    <MudTextField @bind-Value="_tempTitle" OnBlur="() => SaveTitle(context)" Variant="Variant.Outlined" Margin="Margin.Dense" AutoFocus />
                }
                else
                {
                    <MudText @onclick="() => StartEditing(context)" Class="cursor-pointer hover:text-blue-400 font-bold">
                        @context.Title
                    </MudText>
                }
            </MudTd>
            <MudTd DataLabel="Type">@context.Type</MudTd>
            <MudTd DataLabel="Progress">
                <div class="flex items-center">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="() => AdjustProgress(context, -1)" />
                    <MudText Class="mx-2 font-mono text-blue-400">EP @context.Progress</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="() => AdjustProgress(context, 1)" />
                </div>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudSelect T="string" Value="@context.Status" ValueChanged="(s) => UpdateStatus(context, s)" Variant="Variant.Text" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Watching")">Watching</MudSelectItem>
                    <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem Value="@("Plan to Watch")">Plan to Watch</MudSelectItem>
                    <MudSelectItem Value="@("Dropped")">Dropped</MudSelectItem>
                </MudSelect>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<MediaEntry> _myMedia = new();
    private MediaEntry _newEntry = new() { Status = "Watching" };
    private int? _editingId;
    private string _tempTitle = "";

    protected override async Task OnInitializedAsync() => await ReloadFromDisk();

    private async Task ReloadFromDisk()
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        _myMedia = await context.MediaEntries.ToListAsync();
    }

    private async Task AddMedia()
    {
        if (string.IsNullOrWhiteSpace(_newEntry.Title)) return;
        await using var context = await DbFactory.CreateDbContextAsync();
        await context.MediaEntries.AddAsync(_newEntry);
        await context.SaveChangesAsync();
        _newEntry = new MediaEntry { Status = "Watching" };
        await ReloadFromDisk();
    }

    private async Task AdjustProgress(MediaEntry item, int amount)
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        context.MediaEntries.Attach(item);
        item.Progress = Math.Max(0, item.Progress + amount);
        context.Entry(item).Property(x => x.Progress).IsModified = true;
        await context.SaveChangesAsync();
    }

    private async Task UpdateStatus(MediaEntry item, string newStatus)
    {
        if (string.IsNullOrWhiteSpace(newStatus)) return;
        await using var context = await DbFactory.CreateDbContextAsync();
        context.MediaEntries.Attach(item);
        item.Status = newStatus;
        context.Entry(item).Property(x => x.Status).IsModified = true;
        await context.SaveChangesAsync();
        await ReloadFromDisk();
    }

    private void StartEditing(MediaEntry item)
    {
        _editingId = item.Id;
        _tempTitle = item.Title ?? "";
    }

    private async Task SaveTitle(MediaEntry item)
    {
        if (!string.IsNullOrWhiteSpace(_tempTitle))
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            context.MediaEntries.Attach(item);
            item.Title = _tempTitle;
            context.Entry(item).Property(x => x.Title).IsModified = true;
            await context.SaveChangesAsync();
        }
        _editingId = null;
        await ReloadFromDisk();
    }
}