@page "/tracker"
@using FieldLogic.Shared
@using FieldLogic.Web.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject JikanService Jikan
@rendermode InteractiveAuto

<div style="min-height: 100vh; background-color: #020617; width: 100%; display: flex; flex-direction: column;">
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-0 ma-0" Style="flex-grow: 1;">
        
        <MudPaper Elevation="0" Square="true" Class="pa-8 mb-8" Style="background-color: #0f172a; border-bottom: 1px solid #1e293b;">
            <MudContainer MaxWidth="MaxWidth.Large">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Style="color: #3b82f6;" Size="Size.Large" />
                    <MudText Typo="Typo.h4" Class="font-weight-black text-uppercase tracking-tighter" Style="color: white;">
                        MEDIA <span style="color: #60a5fa;">INTELLIGENCE</span> UNIT
                    </MudText>
                </MudStack>
                <MudText Typo="Typo.caption" Style="color: #475569; letter-spacing: 2px;">STATUS: DATABASE CONNECTED // API: JIKAN V4</MudText>
            </MudContainer>
        </MudPaper>

        <MudContainer MaxWidth="MaxWidth.Large" Class="pb-16">
            <MudGrid Justify="Justify.Center">
                
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="4" Class="pa-6" Style="background-color: #0f172a; border: 1px solid #1e293b; border-radius: 12px; position: relative; z-index: 50;">
                        <MudTextField T="string"
                                      Value="@_searchQuery"
                                      Label="SEARCH REGISTRY"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      AdornmentColor="Color.Info"
                                      Immediate="true"
                                      Margin="Margin.Dense"
                                      Style="color: #cbd5e1;" 
                                      Class="custom-search-field"
                                      ValueChanged="OnSearchInput" />

                        @if (_apiResults.Any())
                        {
                            <MudList T="object" Class="mt-2 rounded shadow-xl" 
                                     Style="max-height:400px; overflow-y:auto; background-color: #020617; border: 1px solid #3b82f6; position: absolute; width: 92%; z-index: 100;">
                                @foreach (var api in _apiResults)
                                {
                                    <MudListItem OnClick="@(() => AddFromApi(api))" Ripple="true">
                                        <div class="d-flex align-center">
                                            <MudImage Src="@api.Images?.Jpg?.ImageUrl" Width="35" Height="50" Class="rounded mr-3 shadow" />
                                            <div>
                                                <MudText Typo="Typo.body2" Style="color: white; font-weight: bold;">@api.DisplayTitle</MudText>
                                                <MudText Typo="Typo.caption" Style="color: #60a5fa;">TYPE: @(api.Type ?? "N/A")</MudText>
                                            </div>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="7">
                    <MudTable T="MediaEntry" Items="@_allMedia" Hover="true" Elevation="4" 
                              Class="rounded-xl border border-slate-800" Style="background-color: #0f172a;" GroupBy="@_groupDefinition">
                        <HeaderContent>
                            <MudTh Style="color: #94a3b8; font-size: 0.7rem; letter-spacing: 1px;">INTELLIGENCE</MudTh>
                            <MudTh Style="color: #94a3b8; font-size: 0.7rem; letter-spacing: 1px;">PROGRESS</MudTh>
                            <MudTh Style="color: #94a3b8; font-size: 0.7rem; letter-spacing: 1px;">STATUS</MudTh>
                            <MudTh Style="color: #94a3b8; font-size: 0.7rem; letter-spacing: 1px;">ACTIONS</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="mediaItem">
                            <MudTd DataLabel="INTELLIGENCE">
                                <div class="d-flex align-center">
                                    <MudImage Src="@mediaItem.ImageUrl" Width="35" Height="50" Class="rounded mr-3 shadow" />
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: bold; color: white;">@mediaItem.Title</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #64748b;">@mediaItem.Type</MudText>
                                    </div>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="PROGRESS">
                                <div class="d-flex align-center">
                                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Error" OnClick="@(() => AdjustProgress(mediaItem, -1))" />
                                    <span class="mx-2 font-mono" style="color: white;">@mediaItem.Progress / @(mediaItem.TotalEpisodes ?? 0)</span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Success" OnClick="@(() => AdjustProgress(mediaItem, 1))" />
                                </div>
                            </MudTd>
                            <MudTd DataLabel="STATUS">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">@mediaItem.Status</MudChip>
                            </MudTd>
                            <MudTd DataLabel="ACTIONS">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Style="color: #94a3b8;" Size="Size.Small" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </MudContainer>
</div>

<style>
    .custom-search-field .mud-input-label { color: #94a3b8 !important; }
</style>

@code {
    private List<MediaEntry> _allMedia = [];
    private List<AnimeData> _apiResults = [];
    private string _searchQuery = "";
    private System.Threading.Timer? _debounceTimer;

    private TableGroupDefinition<MediaEntry> _groupDefinition = new() { GroupName = "Type", Selector = (e) => e.Type ?? "Anime" };

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _allMedia = await db.MediaEntries.OrderByDescending(x => x.Id).ToListAsync();
    }

    private void OnSearchInput(string text)
    {
        _searchQuery = text;
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(_ => { InvokeAsync(async () => await ExecuteSearch(text)); }, null, 400, System.Threading.Timeout.Infinite);
    }

    private async Task ExecuteSearch(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) { _apiResults.Clear(); await InvokeAsync(StateHasChanged); return; }
        var animeTask = Jikan.SearchAnimeAsync(text);
        var mangaTask = Jikan.SearchMangaAsync(text);
        await Task.WhenAll(animeTask, mangaTask);
        _apiResults = [.. animeTask.Result ?? [], .. mangaTask.Result ?? []];
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task AddFromApi(AnimeData api)
    {
        var apiType = api.Type?.ToLower() ?? "anime";
        string cat = apiType.Contains("novel") ? "Light Novel" : (apiType.Contains("manga") ? "Manga" : "Anime");
        var entry = new MediaEntry { Title = api.Title, EnglishTitle = api.TitleEnglish, ImageUrl = api.Images?.Jpg?.ImageUrl, Type = cat, Status = cat == "Anime" ? "Plan to Watch" : "Plan to Read", Progress = 0, TotalEpisodes = api.Episodes };
        await using var db = await DbFactory.CreateDbContextAsync();
        db.MediaEntries.Add(entry);
        await db.SaveChangesAsync();
        _searchQuery = ""; _apiResults.Clear(); await LoadAll(); await InvokeAsync(StateHasChanged);
    }

    private async Task AdjustProgress(MediaEntry item, int amount)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entry = await db.MediaEntries.FindAsync(item.Id);
        if (entry != null) { entry.Progress += amount; await db.SaveChangesAsync(); await LoadAll(); }
    }

    private async Task UpdateStatus(MediaEntry item, string status)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entry = await db.MediaEntries.FindAsync(item.Id);
        if (entry != null) { entry.Status = status; await db.SaveChangesAsync(); await LoadAll(); }
    }
}