@page "/"
@inject NavigationManager Nav

<PageTitle>Command Center | FieldLogic-Sys</PageTitle>

<div style="min-height: 100vh; background-color: #020617; width: 100%; display: flex; flex-direction: column;">
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-0 ma-0">
        
        @* Hero Section - pt-32 adds space between Navbar and your Name *@
        <MudPaper Elevation="0" Square="true" 
                  Class="d-flex flex-column align-center justify-center pt-32 pb-16 px-6" 
                  Style="background-color: #0f172a; border-bottom: 1px solid #1e293b; width: 100%; margin-top: -64px;">
            
            <MudImage Src="images/logo.png" Alt="FieldLogic Logo" Width="224" Class="mb-8" 
                      Style="filter: drop-shadow(0 0 10px rgba(37, 99, 235, 0.4));" />
            
            <MudText Typo="Typo.h2" Style="color: white; font-weight: 900; text-transform: uppercase; letter-spacing: -2px;">
                Anthony Edward Aldea
            </MudText>
            
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-6">
                <div style="height: 1px; width: 32px; background-color: #2563eb;"></div>
                <MudText Typo="Typo.overline" Style="color: #60a5fa; letter-spacing: 3px;">Systems Architect | AI Candidate</MudText>
                <div style="height: 1px; width: 32px; background-color: #2563eb;"></div>
            </MudStack>

            <MudText Typo="Typo.body1" Style="color: #94a3b8; max-width: 600px; font-style: italic; font-family: 'serif';">
                "Control the memory, control the machine."
            </MudText>
        </MudPaper>

        @* Modules Grid *@
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-10 px-10 pb-16">
            <MudGrid Spacing="6" Justify="Justify.Center">
                
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="4" Class="pa-8 cursor-pointer hover-card" 
                              Style="background-color: #0f172a; border: 1px solid #1e293b; border-radius: 16px; height: 100%; position: relative; z-index: 50;"
                              @onclick="@(() => Nav.NavigateTo("tracker"))">
                        <MudText Typo="Typo.h5" Style="color: white; font-weight: bold;" Class="mb-3">Media Tracker</MudText>
                        <MudText Typo="Typo.body2" Style="color: #94a3b8;">
                            Anime and Manga intelligence gathering.
                        </MudText>
                        <MudText Typo="Typo.button" Class="mt-6 d-block" Style="color: #3b82f6; font-weight: bold;">ACCESS MODULE →</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="4" Class="pa-8 cursor-pointer hover-card" 
                              Style="background-color: #0f172a; border: 1px solid #2563eb; border-radius: 16px; height: 100%; position: relative; z-index: 50;"
                              @onclick="@(() => Nav.NavigateTo("intelligence"))">
                        <MudText Typo="Typo.h5" Style="color: white; font-weight: bold;" Class="mb-3">Intelligence Unit</MudText>
                        <MudText Typo="Typo.body2" Style="color: #94a3b8;">
                            Field hardware documentation and research repository.
                        </MudText>
                        <MudText Typo="Typo.button" Class="mt-6 d-block" Style="color: #3b82f6; font-weight: bold;">ACCESS MODULE →</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="pa-8" 
                              Style="background-color: #020617; border: 1px solid #0f172a; border-radius: 16px; height: 100%; opacity: 0.3;">
                        <MudText Typo="Typo.h5" Style="color: #475569; font-weight: bold;" Class="mb-3 uppercase">Technical Labs</MudText>
                        <MudText Typo="Typo.body2" Style="color: #475569;">WGU MSSWEAIE Portfolio projects.</MudText>
                        <MudText Typo="Typo.caption" Class="mt-6 d-block" Style="color: #1e293b; font-family: monospace;">STATUS: OFFLINE</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </MudContainer>
</div>

<style>
    .hover-card { transition: all 0.3s ease; }
    .hover-card:hover { transform: translateY(-4px); border-color: #3b82f6 !important; background-color: #1e293b !important; }
</style>