<MudAppBar Elevation="1" Dense="true" Class="bg-slate-900 border-b border-slate-800">
    <MudText Typo="Typo.h6" Class="font-black tracking-tighter text-blue-500 uppercase">
        FieldLogic<span class="text-slate-100">Systems</span>
    </MudText>
    
    <MudSpacer />

    @* Navigation Links as Sleek Buttons *@
    <MudButton Variant="Variant.Text" Href="/" StartIcon="@Icons.Material.Filled.Dashboard" Class="mx-2 text-slate-300">Home</MudButton>
    <MudButton Variant="Variant.Text" Href="/tracker" StartIcon="@Icons.Material.Filled.Analytics" Class="mx-2 text-slate-300">Tracker</MudButton>
    <MudButton Variant="Variant.Text" Href="/manage" StartIcon="@Icons.Material.Filled.Settings" Class="mx-2 text-slate-300">Manage</MudButton>

    <MudSpacer />

    @* Future Identity Section (Login/User Roles) *@
    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Edge="Edge.End" />
</MudAppBar>